# ── Dev local (pnpm dev + docker compose -f docker-compose.dev.yml up -d) ──
DATABASE_URL="postgresql://deyno:deyno@localhost:5436/deyno"
BETTER_AUTH_URL=http://localhost:3005
# gere com: openssl rand -hex 32
BETTER_AUTH_SECRET=

# ── Produção (docker compose up -d) ──
# senha do Postgres do compose
POSTGRES_PASSWORD=
# URL pública do app (domínio do Cloudflare Tunnel)
PUBLIC_URL=https://deyno.seudominio.com
# token do túnel (Cloudflare Zero Trust → Tunnels; aponte para http://app:3000)
CLOUDFLARE_TUNNEL_TOKEN=
